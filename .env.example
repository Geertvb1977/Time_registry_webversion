# PostgreSQL Database Settings
POSTGRES_DB=time_registry
POSTGRES_USER=time_registry_user
POSTGRES_PASSWORD=ChangeMeToAStrongPassword123!
DJANGO_SECRET_KEY=ChangeMeToARandomSecretKey
EMAIL_HOST_USER=EmailHostUsername
EMAIL_HOST_PASSWORD=EmailHostPassword
FIELD_ENCRYPTION_KEY=FieldEncryptionKeyForSensitiveData
APP_API_KEY=FakeAPIKeyForAppIntegration
LOG_LEVEL=INFO
LOGURU_LEVEL=INFO

# Django Settings
DEBUG=False
ALLOWED_HOSTS=localhost,127.0.0.1,yourdomain.com

# Traefik Settings
DOMAIN=yourdomain.com
TRAEFIK_DOMAIN=yourdomain.com

# CSRF and Security
CSRF_TRUSTED_ORIGINS=https://yourdomain.com,http://yourdomain.com

# Docker Settings
DOCKER_API_VERSION=1.52

